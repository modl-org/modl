#!/bin/sh
# Pre-commit hook: enforce formatting and clippy before committing
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: ./install-hooks.sh

set -e

echo "Running cargo fmt..."
cargo fmt --all 2>/dev/null
# Stage any files that fmt changed
git diff --name-only | xargs -r git add

echo "Running cargo clippy..."
if ! cargo clippy --all-targets -- -D warnings 2>/dev/null; then
    echo ""
    echo "❌ Clippy check failed. Fix the warnings above."
    exit 1
fi

echo "✅ Pre-commit checks passed."
